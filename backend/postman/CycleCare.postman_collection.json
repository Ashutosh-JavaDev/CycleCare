{
  "info": {
    "name": "CycleCare API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"email\": \"priya@example.com\",\n  \"password\": \"password123\",\n  \"age\": 20,\n  \"cycleLength\": 28\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"priya@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Create Period Log",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/period", "host": ["{{baseUrl}}"], "path": ["api", "period"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"startDate\": \"2025-03-01\",\n  \"endDate\": \"2025-03-05\",\n  \"cycleLength\": 28\n}"
        }
      }
    },
    {
      "name": "Create Symptom Log",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/symptoms", "host": ["{{baseUrl}}"], "path": ["api", "symptoms"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\": \"2025-03-02\",\n  \"symptomType\": \"Cramps\",\n  \"painLevel\": 7,\n  \"notes\": \"Strong cramps during classes\"\n}"
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "token", "value": "" }
  ]
}